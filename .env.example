# Discord Jobs Skill - Variables de Entorno
# Copiá este archivo a .env y completá con tus credenciales

# Token del Bot de Discord
# Cómo obtenerlo: https://discord.com/developers/applications
# 1. Crear una aplicación → 2. Ir a "Bot" → 3. Reset Token → 4. Copiar
DISCORD_BOT_TOKEN=tu_token_aqui

# ID del Forum Channel donde se publican las ofertas
# Cómo obtenerlo: Activar Modo Desarrollador en Discord → Click derecho en el canal → Copiar ID
DISCORD_CHANNEL_ID=123456787654321098
